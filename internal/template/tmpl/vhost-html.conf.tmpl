docRoot                   {{.WebRoot}}/htdocs
vhDomain                  {{.Domain}}
enableGzip                1
{{if .SSLEnabled}}ssl {
  certFile                 {{.CertPath}}
  keyFile                  {{.KeyPath}}
  certChain                1
}

{{end}}
index  {
  useServer               0
  indexFiles              index.html, index.htm
}

errorlog {{.LogDir}}/{{.Site}}.error.log {
  useServer               0
  logLevel                WARN
}

accesslog {{.LogDir}}/{{.Site}}.access.log {
  useServer               0
  logFormat               "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\""
}
{{if .SSLEnabled}}
context / {
  location                $DOC_ROOT/
  allowBrowse             1

  rewrite  {
    enable                1
    rules                 <<<END
RewriteCond %{SERVER_PORT} 80
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
    END
  }
}
{{end}}