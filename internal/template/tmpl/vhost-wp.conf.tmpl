docRoot                   {{.WebRoot}}/htdocs
vhDomain                  {{.Domain}}
enableGzip                1
{{if .SSLEnabled}}vhssl {
  certFile                 {{.CertPath}}
  keyFile                  {{.KeyPath}}
  certChain                1
}

{{end}}{{if and .SSLEnabled .HSTS}}extraHeaders              <<<END
Strict-Transport-Security: max-age=31536000; includeSubDomains
END

{{end}}
index  {
  useServer               0
  indexFiles              index.php, index.html
}

errorlog {{.LogDir}}/{{.Site}}.error.log {
  useServer               0
  logLevel                WARN
}

accesslog {{.LogDir}}/{{.Site}}.access.log {
  useServer               0
  logFormat               "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\""
}

scripthandler  {
  add                     lsapi:lsphp-{{.Site}} php
}

extprocessor lsphp-{{.Site}} {
  type                    lsapi
  address                 uds://tmp/lshttpd/{{.Site}}.sock
  maxConns                {{.Children}}
  env                     PHP_LSAPI_CHILDREN={{.Children}}
  env                     PHP_LSAPI_MAX_REQUESTS=1000
  env                     PHP_MEMORY_LIMIT={{.PHPMemoryLimitMB}}M
  env                     LSAPI_AVOID_FORK=200M
  initTimeout             60
  retryTimeout            0
  persistConn             1
  pcKeepAliveTimeout      30
  respBuffer              0
  autoStart               2
  path                    /usr/local/lsws/lsphp{{.PHPVer}}/bin/lsphp
  backlog                 100
  instances               1
  priority                0
  memSoftLimit            {{.MemSoftMB}}M
  memHardLimit            {{.MemHardMB}}M
  procSoftLimit           {{.Children}}
  procHardLimit           {{mul .Children 2}}
  runOnStartUp            1
}

context / {
  location                $DOC_ROOT/
  allowBrowse             1

  rewrite  {
    enable                1
    rules                 <<<END
{{if eq .CacheMode "lscache"}}CacheLookup on
{{end}}{{if .SSLEnabled}}RewriteCond %{SERVER_PORT} 80
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
{{end}}RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.php [L]
    END
  }
{{if eq .CacheMode "lscache"}}
  cache  {
    enableCache           1
    qsCache               1
    reqCookieCache        1
    respCookieCache       1
    ignoreReqCacheCtrl    1
    ignoreRespCacheCtrl   0
    enablePrivateCache    1
    privateExpireInSeconds 1800
    expireInSeconds       1800
  }
{{end}}}

context /wp-config.php {
  location                $DOC_ROOT/wp-config.php
  allowBrowse             0

  accessControl  {
    deny                  *
  }
}

context /xmlrpc.php {
  location                $DOC_ROOT/xmlrpc.php
  allowBrowse             0

  accessControl  {
    allow                 127.0.0.1
    deny                  *
  }
}

{{if eq .CacheMode "lscache"}}cacheroot                 /var/cache/lshttpd/{{.Site}}
{{end}}