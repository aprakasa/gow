docRoot                   {{.WebRoot}}/htdocs
vhDomain                  {{.Domain}}
enableGzip                1
{{if .SSLEnabled}}vhssl {
  certFile                 {{.CertPath}}
  keyFile                  {{.KeyPath}}
  certChain                1
}

{{end}}index  {
  useServer               0
  indexFiles              index.php
}

errorlog {{.LogDir}}/{{.Site}}.error.log {
  useServer               0
  logLevel                WARN
}

accesslog {{.LogDir}}/{{.Site}}.access.log {
  useServer               0
  logFormat               "%h %l %u %t \"%r\" %>s %b \"%{Referer}i\" \"%{User-Agent}i\""
}

scripthandler  {
  add                     lsapi:lsphp-{{.Site}} php
}

extprocessor lsphp-{{.Site}} {
  type                    lsapi
  address                 uds://tmp/lshttpd/{{.Site}}.sock
  maxConns                1
  env                     PHP_LSAPI_CHILDREN=1
  env                     LSAPI_AVOID_FORK=200M
  initTimeout             60
  retryTimeout            0
  persistConn             1
  pcKeepAliveTimeout      30
  respBuffer              0
  autoStart               2
  path                    /usr/local/lsws/lsphp{{.PHPVer}}/bin/lsphp
  backlog                 100
  instances               1
  priority                0
  memSoftLimit            32M
  memHardLimit            64M
  procSoftLimit           1
  procHardLimit           2
  runOnStartUp            1
}

context / {
  location                $DOC_ROOT/
  allowBrowse             1

  rewrite  {
    enable                1
    rules                 <<<END
{{if .SSLEnabled}}RewriteCond %{SERVER_PORT} 80
RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
{{end}}RewriteCond %{REQUEST_URI} !^/maintenance\.php$
RewriteRule .* maintenance.php [L]
    END
  }
}
